{
    "name": "mergify-browser-extension",
    "scripts": {
        "lint": "biome check",
        "format": "biome check --write",
        "test": "jest",
        "start": "npm run dev",
        "dev": "npm run dev:build && npm run dev:watch",
        "dev:build": "make dev-build",
        "dev:watch": "nodemon --watch src --ext js,json,png --exec \"make dev-build\"",
        "dev:clean": "make dev-clean"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@swc/core": "^1.15.33",
        "@swc/jest": "^0.2.39",
        "esbuild": "^0.28.0",
        "jest": "^30.4.0",
        "jest-environment-jsdom": "^30.4.1",
        "nodemon": "^3.1.14"
    }
}
